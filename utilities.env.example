# Copy to ../utilities.env (one directory ABOVE this webroot) and fill in.
# connect-DB.php loads it from the parent directory via phpdotenv so secrets
# never live inside the web-served tree. Never commit the real file.

DB_HOST=webdb.uvm.edu
DB_NAME=
DB_USER=
DB_PASS=
DB_USE_SSL=false
DB_SSL_CA_PATH=

EMAIL_PASS=
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587

APP_BASE_URL=https://utilities.aperkel.w3.uvm.edu
APP_EMAIL_FROM_ADDRESS=
APP_EMAIL_FROM_NAME=77 N Union Utilities
APP_CONFIRMATION_EMAIL_TO=
APP_BILLS_PER_PAGE=10

# Local dev only: set to a UVM NetID to mock CAS. Leave empty in production.
APP_LOCAL_DEV_USER=
