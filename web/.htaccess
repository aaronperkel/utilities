# =============================================================================
# Security (flat deploy: includes/, vendor/, scripts/ live next to index.php)
# =============================================================================
# Block .env and similar from being downloaded as static files.
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Forbid URLs under these paths (PHP still loads them from disk via require).
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(includes|vendor|scripts)(/|$) - [F,L]
</IfModule>

# =============================================================================
# UVM CAS (your server)
# =============================================================================
AuthType CAS
Require ldap-filter |(uid=aperkel)(uid=oacook)(uid=bquacken)
