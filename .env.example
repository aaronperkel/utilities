# Copy to .env.local and fill in. Never commit the real file.

# Database (UVM network / VPN required)
DB_HOST=webdb.uvm.edu
DB_NAME=
DB_USER=
DB_PASS=
DB_USE_SSL=false
DB_SSL_CA_PATH=

# Email (iCloud SMTP)
EMAIL_PASS=
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
APP_EMAIL_FROM_ADDRESS=
APP_EMAIL_FROM_NAME=77 N Union Utilities
APP_CONFIRMATION_EMAIL_TO=

# App
APP_BASE_URL=https://utilities.aaronperkel.com
APP_BILLS_PER_PAGE=10

# Auth (interim passphrase gate; CAS was removed when the site left UVM hosting)
SESSION_SECRET=          # openssl rand -hex 32
SITE_PASSPHRASE=         # what the login page asks for; login always fails while unset
SITE_OWNER_UID=aperkel   # tblPeople.uid the passphrase session logs in as
APP_LOCAL_DEV_USER=      # set to a uid to bypass login locally; empty in production

# Bill PDF storage (absolute path recommended; defaults to ./bill-pdfs)
BILLS_DIR=

# Public unpaid-bills API (leave empty to disable the endpoint)
API_KEY=
HMAC_KEY=
